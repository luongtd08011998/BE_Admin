# Sao chép thành file .env trong thư mục BE_Admin (cùng cấp pom.xml), không commit.
# Ứng dụng tự nạp .env khi khởi động (DotenvEnvironmentPostProcessor).
#
# Map TVAN VNPT: UserName → VNPT_PORTAL_USERNAME, Password → VNPT_PORTAL_PASSWORD.
# Mật khẩu có ký tự # → trong .env phải bọc ngoặc kép, ví dụ: VNPT_PORTAL_PASSWORD="mật-khẩu-có-#"

VNPT_PORTAL_SERVICE_URL=https://YOUR-HOST/PortalService.asmx
VNPT_PORTAL_USERNAME=
VNPT_PORTAL_PASSWORD=